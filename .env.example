# Slack App Configuration
SHERLOCK_SLACK_BOT_TOKEN=xoxb-your-bot-token
SHERLOCK_SLACK_APP_TOKEN=xapp-your-app-token
SHERLOCK_SLACK_SIGNING_SECRET=your-signing-secret
SHERLOCK_SLACK_MODE=socket

# Postgres
SHERLOCK_POSTGRES_DSN=postgres://sherlock:sherlock@localhost:5432/sherlock?sslmode=disable

# NATS
SHERLOCK_NATS_URL=nats://localhost:4222

# S3-compatible Object Storage (MinIO for local dev)
SHERLOCK_S3_ENDPOINT=http://localhost:9000
SHERLOCK_S3_BUCKET=sherlock
SHERLOCK_S3_ACCESS_KEY=minioadmin
SHERLOCK_S3_SECRET_KEY=minioadmin

# Collectors
SHERLOCK_PROMETHEUS_URL=http://localhost:9090
SHERLOCK_LOKI_URL=http://localhost:3100
SHERLOCK_K8S_IN_CLUSTER=false

# Receivers
SHERLOCK_GRAFANA_HMAC_SECRET=
SHERLOCK_ALERTMANAGER_SECRET=
SHERLOCK_GITHUB_WEBHOOK_SECRET=
SHERLOCK_GITLAB_SECRET_TOKEN=

# LLM (optional -- enables AI-powered multi-pass investigation)
SHERLOCK_LLM_ENABLED=false
SHERLOCK_LLM_PROVIDER=openai
SHERLOCK_LLM_MODEL=gpt-4o
SHERLOCK_LLM_API_KEY=
SHERLOCK_LLM_ENDPOINT=
SHERLOCK_LLM_GCP_PROJECT=
SHERLOCK_LLM_GCP_REGION=us-central1
SHERLOCK_LLM_TEMPERATURE=0.2
SHERLOCK_LLM_MAX_TOKENS=4096
SHERLOCK_LLM_MAX_PASSES=3
SHERLOCK_LLM_TIMEOUT=120s

# Git Source Access (optional -- enables source code analysis)
SHERLOCK_GIT_ENABLED=false
SHERLOCK_GIT_PROVIDER=github
SHERLOCK_GIT_TOKEN=
SHERLOCK_GIT_ORGANIZATION=
SHERLOCK_GIT_DEFAULT_BRANCH=main

# Deduplication
SHERLOCK_DEDUP_ENABLED=true
SHERLOCK_DEDUP_WINDOW=1h

# Remediation Policies (optional)
SHERLOCK_REMEDIATION_ENABLED=true
SHERLOCK_REMEDIATION_POLICIES_PATH=

# Observability (optional -- OpenTelemetry tracing)
SHERLOCK_TRACING_ENABLED=false
SHERLOCK_TRACING_ENDPOINT=localhost:4318
SHERLOCK_TRACING_SAMPLE_RATE=1.0

# Security
SHERLOCK_API_KEY=
SHERLOCK_RATE_LIMIT_RPS=50
SHERLOCK_RATE_LIMIT_BURST=100
SHERLOCK_STRICT_WEBHOOK_AUTH=false
